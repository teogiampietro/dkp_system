@using DkpSystem.Services
@rendermode InteractiveServer
@inject IToastService ToastService
@implements IDisposable

<div class="toast-container" aria-live="polite" aria-atomic="false">
    @foreach (var toast in _toasts)
    {
        <div class="toast-notification toast-@toast.Type.ToString().ToLower() show"
             @key="toast.Id"
             role="alert"
             @onclick="() => ToastService.Dismiss(toast.Id)">
            <div class="toast-body">
                <span class="toast-icon">@GetIcon(toast.Type)</span>
                <span class="toast-message">@toast.Message</span>
                <button class="toast-close"
                        @onclick="() => ToastService.Dismiss(toast.Id)"
                        @onclick:stopPropagation="true"
                        aria-label="Close">×</button>
            </div>
            <div class="toast-progress"></div>
        </div>
    }
</div>

<style>
    .toast-container {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 10050;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        pointer-events: none;
    }

    .toast-notification {
        position: relative;
        min-width: 300px;
        max-width: 400px;
        background-color: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--border-default);
        border-left-width: 4px;
        border-radius: 6px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        pointer-events: all;
        cursor: pointer;
        overflow: hidden;
        animation: toast-slide-in 0.25s ease forwards;
        opacity: 0;
    }

    .toast-notification.show {
        animation: toast-slide-in 0.25s ease forwards, toast-fade-out 0.35s ease 4.65s forwards;
    }

    @@keyframes toast-slide-in {
        from { opacity: 0; transform: translateX(110%); }
        to   { opacity: 1; transform: translateX(0); }
    }

    @@keyframes toast-fade-out {
        from { opacity: 1; }
        to   { opacity: 0; transform: translateX(110%); }
    }

    .toast-body {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem;
    }

    .toast-icon { font-size: 1rem; flex-shrink: 0; line-height: 1; }
    .toast-message { flex-grow: 1; font-size: 13px; line-height: 1.4; }

    .toast-close {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.2rem;
        line-height: 1;
        padding: 0 0 0 0.5rem;
        cursor: pointer;
        opacity: 0.7;
        flex-shrink: 0;
        transition: opacity 150ms ease, color 150ms ease;
    }
    .toast-close:hover { opacity: 1; color: var(--text-primary); }

    .toast-progress {
        position: absolute;
        left: 0; bottom: 0;
        height: 2px;
        background: currentColor;
        opacity: 0.4;
        width: 100%;
        transform-origin: left;
        animation: toast-progress 5s linear forwards;
    }
    @@keyframes toast-progress {
        from { transform: scaleX(1); }
        to   { transform: scaleX(0); }
    }

    .toast-success { border-left-color: var(--success); color: var(--text-primary); }
    .toast-success .toast-icon, .toast-success .toast-progress { color: var(--success); }

    .toast-error   { border-left-color: var(--danger); }
    .toast-error   .toast-icon, .toast-error   .toast-progress { color: var(--danger); }

    .toast-warning { border-left-color: var(--warning); }
    .toast-warning .toast-icon, .toast-warning .toast-progress { color: var(--warning); }

    .toast-info    { border-left-color: var(--accent-blue); }
    .toast-info    .toast-icon, .toast-info    .toast-progress { color: var(--accent-blue); }
</style>

@code {
    private List<ToastMessage> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnChange += HandleChange;
    }

    private void HandleChange()
    {
        var updated = ToastService.Toasts.ToList();
        var added = updated.Where(t => _toasts.All(x => x.Id != t.Id)).ToList();
        _toasts = updated;
        InvokeAsync(StateHasChanged);

        foreach (var toast in added)
            _ = AutoDismiss(toast.Id);
    }

    private async Task AutoDismiss(Guid id)
    {
        await Task.Delay(5000);
        ToastService.Dismiss(id);
    }

    private static string GetIcon(ToastType type) => type switch
    {
        ToastType.Success => "✓",
        ToastType.Error   => "✕",
        ToastType.Warning => "⚠",
        _                 => "ℹ",
    };

    public void Dispose()
    {
        ToastService.OnChange -= HandleChange;
    }
}
