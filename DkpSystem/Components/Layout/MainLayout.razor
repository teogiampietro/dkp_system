@inherits LayoutComponentBase

<div class="page">
    <AuthorizeView>
        <Authorized>
            <div class="sidebar">
                <NavMenu/>
            </div>
        </Authorized>
    </AuthorizeView>
    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">
                        Welcome, <strong>@context.User.Identity?.Name</strong>
                        @{
                            var roleLabel = context.User.IsInRole("admin") ? "Admin"
                                : context.User.IsInRole("officer") ? "Officer"
                                : "Raider";
                            var roleVariant = context.User.IsInRole("admin") ? "danger"
                                : context.User.IsInRole("officer") ? "warning"
                                : "primary";
                        }
                        <a href="/profile" class="btn btn-sm btn-outline-@roleVariant" role="button">
                            @roleLabel
                        </a>
                    </span>
                    <LogoutButton/>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-sm btn-primary me-2">Login</a>
                    <a href="/register" class="btn btn-sm btn-outline-primary">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>


        @Body

    </main>
</div>

<ToastContainer />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
