@page "/unauthorized"

<PageTitle>Unauthorized - DKP System</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3>
                        <i class="bi bi-shield-exclamation"></i>
                        Access Denied
                    </h3>
                </div>
                <div class="card-body">
                    <h4 class="text-danger mb-4">Unauthorized Access</h4>
                    <p class="lead">
                        You do not have permission to access this page.
                    </p>
                    <p class="text-muted">
                        This area is restricted to administrators only. If you believe you should have access,
                        please contact your guild administrator.
                    </p>
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary me-2">
                            <i class="bi bi-house"></i> Go to Home
                        </a>
                        <a href="/profile" class="btn btn-secondary">
                            <i class="bi bi-person"></i> My Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
