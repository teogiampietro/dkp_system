@page "/admin/members/{id:guid}/reset-password"
@using DkpSystem.Services
@using DkpSystem.Models
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "admin")]
@rendermode InteractiveServer

<PageTitle>Reset Password</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Reset Member Password</h1>
        <button class="btn btn-secondary" @onclick="NavigateBack">
            Back to Member
        </button>
    </div>

    @if (_errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    @if (_successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_member == null)
    {
        <div class="alert alert-warning">Member not found.</div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5>Reset Password for @_member.Username</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <strong>Important:</strong> You are about to set a temporary password for this member. 
                            Make sure to communicate this password to them securely outside of the system. 
                            They should change it after logging in.
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="text" class="form-control" value="@_member.Email" disabled />
                        </div>

                        <EditForm Model="@_resetModel" OnValidSubmit="HandleResetPassword">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger" />

                            <div class="mb-3">
                                <label for="temporaryPassword" class="form-label">Temporary Password</label>
                                <InputText id="temporaryPassword" 
                                          class="form-control" 
                                          type="password"
                                          @bind-Value="_resetModel.TemporaryPassword" />
                                <div class="form-text">Minimum 6 characters.</div>
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <InputText id="confirmPassword" 
                                          class="form-control" 
                                          type="password"
                                          @bind-Value="_resetModel.ConfirmPassword" />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-warning" disabled="@_resetting">
                                    @if (_resetting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    Reset Password
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

