@page "/admin/auctions/new"
@using DkpSystem.Services
@using DkpSystem.Data.Repositories
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "admin")]
@rendermode InteractiveServer
@inject AuctionService AuctionService
@inject ImageStorageService ImageStorageService
@inject UserRepository UserRepository
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Create Auction</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h2>Create New Auction</h2>

            @if (_preloadedItemCount > 0)
            {
                <div class="alert alert-info" role="alert">
                    <strong>@_preloadedItemCount item(s) pre-loaded</strong> from the previous auction. Adjust minimum bids as needed before creating the new auction.
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @_errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @_successMessage
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" FormName="AuctionForm">
                        <AntiforgeryToken />
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="auctionName" class="form-label">Auction Name</label>
                            <InputText id="auctionName" class="form-control" @bind-Value="_model.Name" placeholder="e.g., Weekly Raid Loot - Week 15" />
                            <ValidationMessage For="@(() => _model.Name)" />
                        </div>

                        <div class="mb-3">
                            <label for="closesAt" class="form-label">Closes At</label>
                            <input type="datetime-local" id="closesAt" class="form-control"
                                   value="@_model.ClosesAt.ToString("yyyy-MM-ddTHH:mm")"
                                   @onchange="e => { var v = e.Value?.ToString(); if (!string.IsNullOrEmpty(v) && DateTime.TryParse(v, out var dt)) _model.ClosesAt = dt; }" />
                            <small class="form-text text-muted">Date and time when bidding closes.</small>
                        </div>

                        <hr />

                        <h4>Items</h4>
                        <p class="text-muted">Add items that will be auctioned. Paste a screenshot (Ctrl+V) on each item to attach an image.</p>

                        @for (int i = 0; i < _model.Items.Count; i++)
                        {
                            var index = i;
                            var item = _model.Items[index];
                            <div class="card mb-2">
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-md-5">
                                            <label class="form-label">Item Name</label>
                                            <input type="text" class="form-control" @bind="item.Name" placeholder="e.g., Legendary Sword" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Minimum Bid (DKP)</label>
                                            <input type="number" class="form-control" @bind="item.MinimumBid" min="1" />
                                        </div>
                                        <div class="col-md-2 d-flex align-items-end">
                                            <button type="button" class="btn btn-danger w-100" @onclick="() => RemoveItem(index)">
                                                Remove
                                            </button>
                                        </div>
                                    </div>

                                    @* Paste zone *@
                                    <div class="mt-2">
                                        @if (item.ImageDataUrl != null)
                                        {
                                            <div class="d-flex align-items-start gap-2">
                                                <img src="@item.ImageDataUrl"
                                                     alt="Item preview"
                                                     style="max-height:120px; max-width:100%; border-radius:4px; border:1px solid #dee2e6;" />
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => ClearImage(index)">
                                                    ✕ Remove image
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div id="paste-zone-@index"
                                                 tabindex="0"
                                                 class="paste-zone"
                                                 style="border:2px dashed #adb5bd; border-radius:6px; padding:12px 16px; color:#6c757d; cursor:pointer; outline:none; user-select:none;"
                                                 title="Click here and press Ctrl+V to paste a screenshot">
                                                📋 Click here and press <strong>Ctrl+V</strong> to paste a screenshot
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        <button type="button" class="btn btn-secondary mb-3" @onclick="AddItem" @onclick:preventDefault="true">
                            + Add Item
                        </button>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>@_submitStatus</span>
                                }
                                else
                                {
                                    <span>Create Auction</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery]
    public Guid? FromAuctionId { get; set; }

    private AuctionFormModel _model = new();
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private string _submitStatus = string.Empty;
    private bool _isSubmitting = false;
    private int _preloadedItemCount = 0;
    private DotNetObjectReference<AuctionForm>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);

        if (FromAuctionId.HasValue)
        {
            var skippedItems = (await AuctionService.GetUnresolvedItemsAsync(FromAuctionId.Value)).ToList();
            foreach (var item in skippedItems)
            {
                _model.Items.Add(new AuctionItemModel { Name = item.Name, MinimumBid = item.MinimumBid });
            }
            _preloadedItemCount = skippedItems.Count;
        }

        if (_model.Items.Count == 0)
        {
            _model.Items.Add(new AuctionItemModel { Name = "Item 1" });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await InitPasteZonesAsync();
    }

    private async Task InitPasteZonesAsync()
    {
        for (int i = 0; i < _model.Items.Count; i++)
        {
            if (_model.Items[i].ImageDataUrl == null)
            {
                await JSRuntime.InvokeVoidAsync("initAuctionPasteZone", $"paste-zone-{i}", _dotNetRef, i);
            }
        }
    }

    [JSInvokable]
    public void OnImagePasted(int itemIndex, string dataUrl, string mimeType)
    {
        if (itemIndex < 0 || itemIndex >= _model.Items.Count) return;
        _model.Items[itemIndex].ImageDataUrl = dataUrl;
        _model.Items[itemIndex].ImageMimeType = mimeType;
        InvokeAsync(StateHasChanged);
    }

    private void AddItem()
    {
        var nextNumber = _model.Items.Count + 1;
        _model.Items.Add(new AuctionItemModel { Name = $"Item {nextNumber}" });
    }

    private void RemoveItem(int index)
    {
        if (_model.Items.Count > 1)
        {
            _model.Items.RemoveAt(index);
        }
        else
        {
            _errorMessage = "At least one item is required.";
        }
    }

    private void ClearImage(int index)
    {
        _model.Items[index].ImageDataUrl = null;
        _model.Items[index].ImageMimeType = null;
    }

    private async Task HandleSubmit()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isSubmitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Name))
            {
                _errorMessage = "Auction name is required.";
                return;
            }

            if (_model.ClosesAt <= DateTime.Now)
            {
                _errorMessage = "Closing date must be in the future.";
                return;
            }

            if (_model.Items.Count == 0)
            {
                _errorMessage = "At least one item is required.";
                return;
            }

            foreach (var item in _model.Items)
            {
                if (string.IsNullOrWhiteSpace(item.Name))
                {
                    _errorMessage = "All items must have a name.";
                    return;
                }

                if (item.MinimumBid <= 0)
                {
                    _errorMessage = "All items must have a minimum bid greater than zero.";
                    return;
                }
            }

            var authState = await AuthenticationStateTask!;
            var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(userIdClaim) || !Guid.TryParse(userIdClaim, out var userId))
            {
                _errorMessage = "Unable to identify current user.";
                return;
            }

            var user = await UserRepository.FindByIdAsync(userId);
            if (user == null || user.GuildId == null)
            {
                _errorMessage = "You must be assigned to a guild to create auctions.";
                return;
            }

            // Upload images that were pasted
            var itemsWithUrls = new List<(string Name, int MinimumBid, string? ImageUrl)>();
            for (int i = 0; i < _model.Items.Count; i++)
            {
                var item = _model.Items[i];
                string? imageUrl = null;

                if (item.ImageDataUrl != null && item.ImageMimeType != null)
                {
                    _submitStatus = $"Uploading image {i + 1}/{_model.Items.Count}...";
                    StateHasChanged();

                    var base64 = item.ImageDataUrl[(item.ImageDataUrl.IndexOf(',') + 1)..];
                    var imageBytes = Convert.FromBase64String(base64);
                    imageUrl = await ImageStorageService.UploadImageAsync(imageBytes, item.ImageMimeType);
                }

                itemsWithUrls.Add((item.Name, item.MinimumBid, imageUrl));
            }

            _submitStatus = "Creating auction...";
            StateHasChanged();

            var result = await AuctionService.CreateAuctionAsync(
                user.GuildId.Value,
                _model.Name,
                _model.ClosesAt,
                userId,
                itemsWithUrls
            );

            if (result.Success && result.Auction != null)
            {
                _successMessage = "Auction created successfully! Redirecting...";
                await Task.Delay(1000);
                Navigation.NavigateTo($"/auctions/{result.Auction.Id}");
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
            _submitStatus = string.Empty;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/auctions");
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private class AuctionFormModel
    {
        public string Name { get; set; } = string.Empty;
        public DateTime ClosesAt { get; set; } = DateTime.Now.AddHours(24);
        public List<AuctionItemModel> Items { get; set; } = new();
    }

    private class AuctionItemModel
    {
        public string Name { get; set; } = string.Empty;
        public int MinimumBid { get; set; } = 10;
        public string? ImageDataUrl { get; set; }
        public string? ImageMimeType { get; set; }
    }
}
