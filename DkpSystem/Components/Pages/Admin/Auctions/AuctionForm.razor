@page "/admin/auctions/new"
@using DkpSystem.Services
@using DkpSystem.Data.Repositories
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "admin,officer")]
@rendermode InteractiveServer

<PageTitle>Create Auction</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h2>Create New Auction</h2>

            @if (_preloadedItemCount > 0)
            {
                <div class="alert alert-info" role="alert">
                    <strong>@_preloadedItemCount item(s) pre-loaded</strong> from the previous auction. Adjust minimum bids as needed before creating the new auction.
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @_errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @_successMessage
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" FormName="AuctionForm">
                        <AntiforgeryToken />
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="auctionName" class="form-label">Auction Name</label>
                            <InputText id="auctionName" class="form-control" @bind-Value="_model.Name" placeholder="e.g., Weekly Raid Loot - Week 15" />
                            <ValidationMessage For="@(() => _model.Name)" />
                        </div>

                        <div class="mb-3">
                            <label for="auctionDescription" class="form-label">Description <span class="text-muted">(optional)</span></label>
                            <textarea id="auctionDescription" class="form-control" rows="3"
                                      @bind="_model.Description"
                                      placeholder="e.g., Items dropped from last night's raid — Mythic difficulty."></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="closesAt" class="form-label">Closes At</label>
                            <input type="datetime-local" id="closesAt" class="form-control"
                                   value="@_model.ClosesAt.ToString("yyyy-MM-ddTHH:mm")"
                                   @onchange="e => { var v = e.Value?.ToString(); if (!string.IsNullOrEmpty(v) && DateTime.TryParse(v, out var dt)) _model.ClosesAt = dt; }" />
                            <small class="form-text text-muted">Date and time when bidding closes.</small>
                        </div>

                        <hr />

                        <h4>Items</h4>
                        <p class="text-muted">Add items that will be auctioned. Paste a screenshot (Ctrl+V) on each item to attach an image.</p>

                        @for (int i = 0; i < _model.Items.Count; i++)
                        {
                            var index = i;
                            var item = _model.Items[index];
                            <div class="card mb-2">
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-md-5">
                                            <label class="form-label">
                                                Item Name
                                                @if (item.IsOcrPending)
                                                {
                                                    <span class="spinner-border spinner-border-sm ms-2 text-secondary"
                                                          role="status" title="Detecting item name..."></span>
                                                }
                                                else if (item.IsOcrDetected)
                                                {
                                                    <span class="badge bg-success ms-2" title="Auto-detected from screenshot">
                                                        auto-detected
                                                    </span>
                                                }
                                            </label>
                                            <input type="text" class="form-control"
                                                   @bind="item.Name"
                                                   @onfocus="() => { item.IsOcrDetected = false; StateHasChanged(); }"
                                                   placeholder="e.g., Legendary Sword" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Minimum Bid (DKP)</label>
                                            <input type="number" class="form-control" @bind="item.MinimumBid" min="1" />
                                        </div>
                                        <div class="col-md-2 d-flex align-items-end">
                                            <button type="button" class="btn btn-danger w-100" @onclick="() => RemoveItem(index)">
                                                Remove
                                            </button>
                                        </div>
                                    </div>

                                    @* Paste zone *@
                                    <div class="mt-2">
                                        @if (item.ImageDataUrl != null)
                                        {
                                            <div class="d-flex align-items-start gap-2">
                                                <img src="@item.ImageDataUrl"
                                                     alt="Item preview"
                                                     style="max-height:120px; max-width:100%; border-radius:4px; border:1px solid #dee2e6;" />
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => ClearImage(index)">
                                                    ✕ Remove image
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div id="paste-zone-@index"
                                                 tabindex="0"
                                                 class="paste-zone"
                                                 style="border:2px dashed #adb5bd; border-radius:6px; padding:12px 16px; color:#6c757d; cursor:pointer; outline:none; user-select:none;"
                                                 title="Click here and press Ctrl+V to paste a screenshot">
                                                📋 Click here and press <strong>Ctrl+V</strong> to paste a screenshot
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        <button type="button" class="btn btn-secondary mb-3" @onclick="AddItem" @onclick:preventDefault="true">
                            + Add Item
                        </button>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>@_submitStatus</span>
                                }
                                else
                                {
                                    <span>Create Auction</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

