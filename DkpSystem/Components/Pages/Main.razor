@page "/"
@rendermode InteractiveServer

<PageTitle>DKP System</PageTitle>

<!-- Hero -->
<section class="home-hero">
    <div class="home-hero__pattern"></div>
    <div class="home-hero__inner">
        <AuthorizeView>
            <Authorized>
                <div class="home-welcome-banner">
                    <span>Welcome back, <strong>@context.User.Identity?.Name</strong>@if (_userBalance is not null) { <text> — You have <span class="dkp-value">@_userBalance</span> DKP</text> }</span>
                </div>
            </Authorized>
        </AuthorizeView>

        <h1 class="home-hero__title">DKP System</h1>
        <p class="home-hero__tagline">Manage raids, earn DKP, dominate auctions.</p>

        <div class="home-hero__cta">
            <a href="/events" class="btn btn-primary btn-lg">View Upcoming Events</a>
            <AuthorizeView>
                <Authorized>
                    <a href="/dashboard" class="btn btn-outline-primary btn-lg">My DKP Balance</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-outline-primary btn-lg">Sign In</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="home-section">
    <div class="home-stats">
        <div class="home-stat">
            <div class="home-stat__icon">👥</div>
            <div class="home-stat__value">@(_memberCount?.ToString() ?? "—")</div>
            <div class="home-stat__label">Registered Members</div>
        </div>
        <div class="home-stat">
            <div class="home-stat__icon">💰</div>
            <div class="home-stat__value">@(_totalDkpInCirculation?.ToString("N0") ?? "—")</div>
            <div class="home-stat__label">DKP In Circulation</div>
        </div>
        <div class="home-stat">
            <div class="home-stat__icon">⚔️</div>
            <div class="home-stat__value">@(_activeAuctions?.ToString() ?? "—")</div>
            <div class="home-stat__label">Active Auctions</div>
        </div>
        <div class="home-stat">
            <div class="home-stat__icon">🏆</div>
            <div class="home-stat__value">@(_yourRankLabel ?? "—")</div>
            <div class="home-stat__label">Your Rank</div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="home-section">
    <h2 class="home-section__title">Features</h2>
    <div class="home-features">
        <a href="/events" class="home-feature home-feature--blue">
            <div class="home-feature__icon">📅</div>
            <h3>Events</h3>
            <p>Sign up for raids and earn DKP for every attendance.</p>
            <span class="home-feature__link">Go to Events →</span>
        </a>
        <a href="/auctions" class="home-feature home-feature--gold">
            <div class="home-feature__icon">⚒️</div>
            <h3>Auctions</h3>
            <p>Bid on loot using your earned DKP. Fair, transparent, competitive.</p>
            <span class="home-feature__link">Go to Auctions →</span>
        </a>
        <a href="/dashboard" class="home-feature home-feature--purple">
            <div class="home-feature__icon">📊</div>
            <h3>Dashboard</h3>
            <p>Track your rank, history, and DKP balance in real time.</p>
            <span class="home-feature__link">Go to Dashboard →</span>
        </a>
    </div>
</section>

<!-- How it works -->
<section class="home-section">
    <h2 class="home-section__title">How It Works</h2>
    <div class="home-timeline">
        <div class="home-step">
            <div class="home-step__circle">1</div>
            <div class="home-step__title">Attend Events</div>
            <div class="home-step__desc">Show up for raids organized by your guild.</div>
        </div>
        <div class="home-step__line"></div>
        <div class="home-step">
            <div class="home-step__circle">2</div>
            <div class="home-step__title">Earn DKP</div>
            <div class="home-step__desc">Get points for attendance and performance.</div>
        </div>
        <div class="home-step__line"></div>
        <div class="home-step">
            <div class="home-step__circle">3</div>
            <div class="home-step__title">Bid on Loot</div>
            <div class="home-step__desc">Use your DKP to win items at auction.</div>
        </div>
    </div>
</section>

<!-- Recent activity -->
@if (_recentItems.Any())
{
    <section class="home-section">
        <h2 class="home-section__title">Recent Activity</h2>
        <div class="home-activity">
            @foreach (var item in _recentItems.Take(5))
            {
                <div class="home-activity__row">
                    <div class="home-activity__avatar">@GetInitials(item.WinnerName)</div>
                    <div class="home-activity__text">
                        <strong>@item.WinnerName</strong> won <strong>@item.ItemName</strong>
                        for <span class="dkp-value">@item.DkpPaid DKP</span>
                    </div>
                    <div class="home-activity__time">@FormatRelative(item.DeliveredAt)</div>
                </div>
            }
        </div>
    </section>
}

<!-- Footer CTA -->
<section class="home-section home-cta">
    <h3>Ready to raid?</h3>
    <a href="/events" class="btn btn-primary btn-lg">Browse Events →</a>
</section>

<style>
    .home-hero {
        position: relative;
        background-color: var(--bg-secondary);
        border-bottom: 1px solid var(--border-default);
        padding: 4rem 2rem;
        overflow: hidden;
    }
    .home-hero__pattern {
        position: absolute; inset: 0;
        background-image: repeating-linear-gradient(
            135deg,
            transparent 0,
            transparent 14px,
            rgba(88, 166, 255, 0.04) 14px,
            rgba(88, 166, 255, 0.04) 15px
        );
        pointer-events: none;
    }
    .home-hero__inner { position: relative; max-width: 900px; margin: 0 auto; text-align: center; }
    .home-welcome-banner {
        display: inline-block;
        background-color: var(--bg-overlay);
        border: 1px solid var(--border-default);
        border-radius: 999px;
        padding: 0.4rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 13px;
        color: var(--text-secondary);
    }
    .home-welcome-banner .dkp-value { font-weight: 700; }
    .home-hero__title { font-size: 40px; font-weight: 700; margin: 0 0 0.75rem; color: var(--text-primary); }
    .home-hero__tagline { font-size: 18px; color: var(--text-secondary); margin: 0 0 2rem; }
    .home-hero__cta { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

    .home-section { max-width: 1200px; margin: 3rem auto; padding: 0 2rem; }
    .home-section__title {
        font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;
        color: var(--text-muted); font-weight: 600;
        margin-bottom: 1rem;
    }

    .home-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
    .home-stat {
        background-color: var(--bg-elevated);
        border: 1px solid var(--border-default);
        border-radius: 6px;
        padding: 1.25rem;
        text-align: left;
    }
    .home-stat__icon { font-size: 18px; margin-bottom: 0.5rem; }
    .home-stat__value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 28px; font-weight: 700;
        color: var(--accent-gold);
        line-height: 1.1;
    }
    .home-stat__label {
        font-size: 12px; color: var(--text-secondary);
        text-transform: uppercase; letter-spacing: 0.04em;
        margin-top: 0.4rem;
    }

    .home-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
    .home-feature {
        position: relative;
        background-color: var(--bg-elevated);
        border: 1px solid var(--border-default);
        border-top: 3px solid var(--accent-blue);
        border-radius: 6px;
        padding: 1.5rem;
        color: var(--text-primary);
        text-decoration: none;
        transition: transform 150ms ease, border-color 150ms ease;
        display: block;
    }
    .home-feature:hover { transform: translateY(-2px); text-decoration: none; color: var(--text-primary); }
    .home-feature--blue { border-top-color: var(--accent-blue); }
    .home-feature--gold { border-top-color: var(--accent-gold); }
    .home-feature--purple { border-top-color: var(--accent-purple); }
    .home-feature__icon { font-size: 24px; margin-bottom: 0.6rem; }
    .home-feature h3 { font-size: 16px; margin: 0 0 0.5rem; color: var(--text-primary); }
    .home-feature p { color: var(--text-secondary); font-size: 13px; margin: 0 0 1rem; }
    .home-feature__link { color: var(--accent-blue); font-size: 13px; font-weight: 500; }

    .home-timeline {
        display: flex; align-items: center; justify-content: center;
        gap: 0; flex-wrap: wrap;
    }
    .home-step { flex: 0 0 220px; text-align: center; padding: 0.5rem; }
    .home-step__circle {
        width: 48px; height: 48px; border-radius: 50%;
        background: var(--bg-elevated);
        border: 2px solid var(--accent-blue);
        color: var(--accent-blue);
        font-weight: 700; font-size: 18px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 0.75rem;
        font-family: 'JetBrains Mono', monospace;
    }
    .home-step__title { font-weight: 600; color: var(--text-primary); margin-bottom: 0.25rem; }
    .home-step__desc { font-size: 13px; color: var(--text-secondary); }
    .home-step__line { flex: 1; min-width: 30px; height: 1px; background: var(--border-default); margin-top: 1.5rem; }

    .home-activity {
        background-color: var(--bg-elevated);
        border: 1px solid var(--border-default);
        border-radius: 6px;
        overflow: hidden;
    }
    .home-activity__row {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border-default);
    }
    .home-activity__row:last-child { border-bottom: none; }
    .home-activity__avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--bg-overlay);
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 600; color: var(--text-secondary);
        flex-shrink: 0;
    }
    .home-activity__text { flex: 1; font-size: 13px; color: var(--text-secondary); }
    .home-activity__text strong { color: var(--text-primary); }
    .home-activity__time { font-size: 12px; color: var(--text-muted); white-space: nowrap; }

    .home-cta {
        text-align: center;
        padding: 3rem 2rem;
        background-color: var(--bg-secondary);
        border-top: 1px solid var(--border-default);
        border-bottom: 1px solid var(--border-default);
    }
    .home-cta h3 { font-size: 24px; margin-bottom: 1rem; }
</style>
