@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using DkpSystem.Services
@using DkpSystem.Models
@using DkpSystem.Data.Repositories
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My Profile - DKP System</PageTitle>

<div class="container mt-4">
    <h2>My Profile</h2>

    @if (_errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    @if (_user != null)
    {
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4>Account Information</h4>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Username:</dt>
                            <dd class="col-sm-8">@_user.Username</dd>

                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">@_user.Email</dd>

                            <dt class="col-sm-4">Role:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-@(_user.Role == "admin" ? "danger" : "primary")">
                                    @_user.Role.ToUpper()
                                </span>
                            </dd>

                            <dt class="col-sm-4">DKP Balance:</dt>
                            <dd class="col-sm-8">
                                <strong class="text-success fs-4">@_user.DkpBalance</strong>
                            </dd>

                            <dt class="col-sm-4">Guild:</dt>
                            <dd class="col-sm-8">@(_user.GuildId.HasValue ? "Assigned" : "Not assigned")</dd>

                            <dt class="col-sm-4">Member Since:</dt>
                            <dd class="col-sm-8">@_user.CreatedAt.ToString("MMMM dd, yyyy")</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4>Change Password</h4>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(_passwordMessage))
                        {
                            <div
                                class="alert alert-@(_passwordSuccess ? "success" : "danger") alert-dismissible fade show"
                                role="alert">
                                @_passwordMessage
                                <button type="button" class="btn-close"
                                        @onclick="() => _passwordMessage = string.Empty"></button>
                            </div>
                        }

                        <EditForm Model="@_passwordModel" OnValidSubmit="@HandleChangePassword">
                            <DataAnnotationsValidator/>
                            <ValidationSummary class="text-danger"/>

                            <div class="mb-3">
                                <label for="currentPassword" class="form-label">Current Password</label>
                                <InputText id="currentPassword" type="password" class="form-control"
                                           @bind-Value="_passwordModel.CurrentPassword"/>
                            </div>

                            <div class="mb-3">
                                <label for="newPassword" class="form-label">New Password</label>
                                <InputText id="newPassword" type="password" class="form-control"
                                           @bind-Value="_passwordModel.NewPassword"/>
                            </div>

                            <div class="mb-3">
                                <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                                <InputText id="confirmNewPassword" type="password" class="form-control"
                                           @bind-Value="_passwordModel.ConfirmNewPassword"/>
                            </div>

                            <button type="submit" class="btn btn-primary" disabled="@_isChangingPassword">
                                @if (_isChangingPassword)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"
                                          aria-hidden="true"></span>
                                    <span>Changing...</span>
                                }
                                else
                                {
                                    <span>Change Password</span>
                                }
                            </button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Won Items History</h4>
                    </div>
                    <div class="card-body">
                        @if (_wonItemsHistory == null || !_wonItemsHistory.Any())
                        {
                            <p class="text-muted">Items you've won in auctions will appear here.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Auction</th>
                                        <th>Item</th>
                                        <th>DKP Paid</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var item in _wonItemsHistory)
                                    {
                                        <tr>
                                            <td>@item.WonAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@item.AuctionName</td>
                                            <td>@item.ItemName</td>
                                            <td><strong class="text-danger">-@item.DkpPaid</strong></td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>DKP Earnings History</h4>
                    </div>
                    <div class="card-body">
                        @if (_earningsHistory == null || !_earningsHistory.Any())
                        {
                            <p class="text-muted">Your DKP earnings will appear here once you participate in events.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Event</th>
                                        <th>Reason</th>
                                        <th>Points Earned</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var earning in _earningsHistory)
                                    {
                                        <tr>
                                            <td>@earning.EarnedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@earning.EventName</td>
                                            <td>@earning.Reason</td>
                                            <td><strong class="text-success">+@earning.DkpAmount</strong></td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger" role="alert">
            Unable to load profile information.
        </div>
    }
</div>

